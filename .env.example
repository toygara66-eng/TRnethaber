# =============================================================================
# TRNETHABER — Ortam değişkenleri şablonu
# Kopyalayın: cp .env.example .env.local  (Windows: copy .env.example .env.local)
# ASLA .env.local dosyasını git'e commit etmeyin.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (zorunlu — vitrin, admin, bot)
# Dashboard → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# İsteğe bağlı: istemci tarafı (çoğu sorgu sunucuda; yine de önerilir)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Üyelik (Supabase Auth) — Dashboard → Authentication → URL Configuration
# Site URL: http://localhost:3000 (prod: https://trnethaber.vercel.app)
# Redirect URLs: http://localhost:3000/auth/callback, https://YOUR_DOMAIN/auth/callback
# Google SSO: Authentication → Providers → Google (Client ID/Secret)

# Admin CMS + otonom bot INSERT (service_role / secret — GİZLİ)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx

# -----------------------------------------------------------------------------
# Otonom haber botu — /api/cron/news-bot
# -----------------------------------------------------------------------------
# Yerel test: Authorization: Bearer <değer>
# Cron API: Authorization: Bearer <secret> veya ?secret=<aynı değer>
CRON_SECRET_KEY=guclu-rastgele-bir-metin
# Vercel Cron otomatik Bearer gönderirken CRON_SECRET env adını kullanır —
# Dashboard'da CRON_SECRET değerini CRON_SECRET_KEY ile aynı yapın.
# CRON_SECRET=guclu-rastgele-bir-metin

# -----------------------------------------------------------------------------
# Google Gemini — haber sentez motoru
# https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter — Gemini meşgul/kota/timeout yedek motoru (ücretsiz modeller)
# https://openrouter.ai/keys  (sk-or-v1-...)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
# İsteğe bağlı birincil model (varsayılan: openrouter/free otomatik havuz)
# OPENROUTER_MODEL=openrouter/free
# Görsel alaka filtresi (false = yalnızca URL doğrulama)
# GEMINI_VISION_FILTER=true
# Medya kütüphanesi AI etiketleme (false = devre dışı)
# MEDIA_TAGGING_ENABLED=true

# Ek görsel havuzu — en az biri önerilir (haber gövdesi 3+ fotoğraf)
# UNSPLASH_ACCESS_KEY=
# Kimdir bot kapak görseli (Wikipedia sonrası yedek): Google Custom Search Image
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=

# -----------------------------------------------------------------------------
# SEO & Analytics (Google Search Console + GA4)
# -----------------------------------------------------------------------------
# Kanonik alan adı — sitemap.xml, robots.txt, Open Graph
# NEXT_PUBLIC_SITE_URL=https://trnethaber.vercel.app
# Google Analytics 4 ölçüm kimliği (G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Vercel Dashboard → Settings → Environment Variables
# Production + Preview için aynı değişkenleri ekleyin:
#
#   SUPABASE_URL
#   SUPABASE_PUBLISHABLE_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   CRON_SECRET_KEY  (veya CRON_SECRET — Vercel otomatik Bearer gönderir)
#   GEMINI_API_KEY
#   GEMINI_MODEL     (isteğe bağlı, varsayılan: gemini-2.5-flash)
#   NEXT_PUBLIC_SUPABASE_URL          (isteğe bağlı)
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (isteğe bağlı)
#   NEXT_PUBLIC_SITE_URL              (sitemap / canonical)
#   NEXT_PUBLIC_GA_ID                 (Google Analytics 4)
#
# Deprem botu — AFAD API (varsayılan eşik: 4.0)
# EARTHQUAKE_MIN_MAGNITUDE=4.0

# Hammadde avcısı — MEGA RSS havuzu kod içinde (lib/bot/rss-feed-pool.ts)
# RSS_USE_MOCK=true  → yalnızca mock tel (test)

# Karanlık Fabrika — RSS istihbarat + Zeki Assembler
# GET/POST /api/cron/fetch-news
#   Authorization: Bearer <CRON_SECRET veya CRON_SECRET_KEY>
#   Tarayıcı testi (secret, .env ile aynı olmalı — örnek patron123 ise CRON_SECRET_KEY=patron123):
#   http://localhost:3000/api/cron/fetch-news?secret=patron123
# FETCH_NEWS_SOURCE_BATCH=5   (her cron'da karıştırılmış listeden işlenecek kaynak sayısı)
# FETCH_NEWS_MAX_SOURCES=5    (eski ad; SOURCE_BATCH yoksa kullanılır)
# FETCH_NEWS_ITEMS_PER_SOURCE=2
# FETCH_NEWS_MAX_SAVED=5
# FETCH_NEWS_RSS_TIMEOUT_MS=12000
# AI kapak (scrape başarısızsa): Vertex Imagen + Gemini prompt
# GCP_PROJECT_ID=
# GCP_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# VERTEX_IMAGEN_MODEL=imagen-3.0-generate-001
# GEMINI_VISION_FILTER=true

# Cron: vercel.json → her saat başı GET /api/cron/news-bot
# Hobby planda cron günde 1 kez ile sınırlı olabilir; saatlik için Pro gerekir.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Faz 12 — Sosyal medya dağıtım (isteğe bağlı; eksikse paylaşım atlanır)
# Haber DB'ye kaydedildikten sonra Telegram + X (fail-safe)
# -----------------------------------------------------------------------------
# Telegram Bot API — @BotFather token + kanal/grup chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# X (Twitter) API v2 — OAuth 1.0a User context (tweet yazma izni)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
